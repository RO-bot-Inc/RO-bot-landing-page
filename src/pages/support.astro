---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Support - RO-bot" description="Get help with RO-bot. Contact our support team or access the setup guide.">

  <section class="bg-navy pt-28 pb-12 md:pt-36 md:pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-extrabold text-white mb-4">Support</h1>
      <p class="text-lg text-muted">We're here to help you get the most out of RO-bot.</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-surface rounded-2xl p-8 border border-gray-100">
          <h3 class="text-xl font-bold text-navy mb-3">Get Help</h3>
          <p class="text-gray-600 mb-4">
            Need assistance with RO-bot? Reach out and we'll get back to you quickly.
          </p>
          <a href="mailto:hello@ro-bot.io" class="text-teal hover:text-teal-dark font-medium transition-colors">
            hello@ro-bot.io
          </a>
        </div>

        <div class="bg-surface rounded-2xl p-8 border border-gray-100">
          <h3 class="text-xl font-bold text-navy mb-3">Setup Guide</h3>
          <p class="text-gray-600 mb-4">
            Learn how to set up and use RO-bot effectively in your service environment.
          </p>
          <a href="https://celestial-xenon-221.notion.site/RO-bot-Setup-1f2d29c34d6480078746e6c15ad834f7" target="_blank" rel="noopener" class="text-teal hover:text-teal-dark font-medium transition-colors">
            View Setup Guide
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
