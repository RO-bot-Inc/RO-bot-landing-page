</style>

<script>
  const voiceTextEl = document.getElementById('voice-text');
  const timerEl = document.getElementById('demo-timer');
  const waveform = document.getElementById('waveform');
  const recDot = document.getElementById('rec-dot');
  const recLabel = document.getElementById('rec-label');

  const phaseVoice = document.getElementById('phase-voice');
  const phaseWriting = document.getElementById('phase-writing');
  const phaseStory = document.getElementById('phase-story');
  const phaseGrading = document.getElementById('phase-grading');
  const phaseGrade = document.getElementById('phase-grade');

  const voiceContent = "Ok, I verified the overheating issue, let it idle for about ten minutes and yeah the gauge climbed right up. The water pump's leaking from the weep hole. Uh, the thermostat was also... actually it was working but not perfect so I'm replacing that. I put in the new pump and thermostat, refilled the coolant, let it run for uh... fifteen minutes. No leaks, temp is good.";

  let observed = false;
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting && !observed) {
        observed = true;
        runLoop();
      }
    });
  }, { threshold: 0.3 });

  const container = document.getElementById('robo-demo');
  if (container) observer.observe(container);

  async function runLoop() {
    while (true) {
      await runDemo();
      await sleep(3000);
      resetDemo();
    }
  }

  function resetDemo() {
    // Reset all phases to initial state
    if (voiceTextEl) voiceTextEl.textContent = '';
    if (timerEl) timerEl.textContent = '0:00';
    if (waveform) waveform.classList.remove('waveform-active');
    if (recDot) recDot.classList.add('animate-pulse');
    if (recLabel) recLabel.textContent = 'Recording...';

    show(phaseVoice);
    hide(phaseWriting);
    hide(phaseStory);
    hide(phaseGrading);
    hide(phaseGrade);
  }

  async function runDemo() {
    let elapsed = 0;

    // Phase 1: Voice recording with waveform + transcription
    if (waveform) waveform.classList.add('waveform-active');
    const words = voiceContent.split(' ');
    for (let i = 0; i < words.length; i++) {
      const partial = words.slice(0, i + 1).join(' ');
      if (voiceTextEl) voiceTextEl.textContent = partial;
      elapsed += 150;
      updateTimer(elapsed);
      await sleep(150);
    }

    // Stop waveform
    if (waveform) waveform.classList.remove('waveform-active');
    if (recDot) recDot.classList.remove('animate-pulse');
    if (recLabel) recLabel.textContent = 'Done';
    await sleep(500);
    elapsed += 500;
    updateTimer(elapsed);

    // Phase 2: Writing spinner
    hide(phaseVoice);
    show(phaseWriting);
    await sleep(2000);
    elapsed += 2000;
    updateTimer(elapsed);

    // Phase 3: Show 3Cs story
    hide(phaseWriting);
    show(phaseStory);
    await sleep(2000);
    elapsed += 2000;
    updateTimer(elapsed);

    // Phase 4: Grading spinner (below story)
    show(phaseGrading);
    await sleep(1500);
    elapsed += 1500;
    updateTimer(elapsed);

    // Phase 5: Show grades
    hide(phaseGrading);
    show(phaseGrade);
    elapsed += 500;
    updateTimer(elapsed);
  }

  function show(el) { if (el) el.classList.remove('hidden'); }
  function hide(el) { if (el) el.classList.add('hidden'); }

  function updateTimer(ms) {
    if (!timerEl) return;
    const s = Math.floor(ms / 1000);
    const m = Math.floor(s / 60);
    const sec = s % 60;
    timerEl.textContent = `${m}:${sec.toString().padStart(2, '0')}`;
  }

  function sleep(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }
</script>
