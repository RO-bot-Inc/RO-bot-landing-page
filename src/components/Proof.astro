<section id="proof" class="py-20 md:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section heading -->
    <div class="max-w-3xl mx-auto text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-extrabold text-navy mb-6">
        Results from Real Shops
      </h2>
      <p class="text-lg text-gray-600 leading-relaxed">
        R.O. bot is live in real service departments. Here's what we're seeing.
      </p>
    </div>

    <!-- Before/After animation -->
    <div class="mb-20" id="before-after-container">
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Left: The Old Way (typing) -->
        <div class="bg-gray-50 rounded-2xl p-6 md:p-8 border border-gray-200">
          <div class="flex items-center justify-between mb-6">
            <h3 class="font-bold text-navy">The Old Way</h3>
            <span class="text-sm font-mono text-gray-400" id="type-timer">0:00</span>
          </div>
          <div class="bg-white rounded-lg border border-gray-300 p-4 min-h-[160px] font-mono text-sm text-gray-700">
            <span id="typed-text"></span><span id="cursor" class="animate-pulse">|</span>
          </div>
          <p class="text-xs text-gray-400 mt-3">Incomplete. No complaint. No verification. No diagnostic steps.</p>
        </div>

        <!-- Right: With R.O. bot (voice) -->
        <div class="bg-navy/5 rounded-2xl p-6 md:p-8 border border-teal/20">
          <div class="flex items-center justify-between mb-6">
            <h3 class="font-bold text-navy">With R.O. bot</h3>
            <span class="text-sm font-mono text-teal" id="voice-timer">0:00</span>
          </div>

          <!-- Voice waveform phase -->
          <div id="voice-phase" class="mb-4">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-3 h-3 rounded-full bg-red-500 animate-pulse"></div>
              <span class="text-sm text-gray-500">Recording...</span>
            </div>
            <div class="bg-white rounded-lg border border-gray-200 p-4 text-sm text-gray-600 italic min-h-[80px]">
              <span id="voice-text"></span>
            </div>
          </div>

          <!-- 3Cs output phase -->
          <div id="threecs-phase" class="hidden">
            <div class="space-y-3">
              <div class="bg-white rounded-lg p-4 border-l-4 border-blue-500">
                <div class="text-xs font-bold text-blue-600 uppercase tracking-wider mb-1">Complaint</div>
                <p class="text-sm text-gray-700">Customer states the vehicle is overheating.</p>
              </div>
              <div class="bg-white rounded-lg p-4 border-l-4 border-blue-500">
                <div class="text-xs font-bold text-blue-600 uppercase tracking-wider mb-1">Cause</div>
                <p class="text-sm text-gray-700">Customer concern regarding vehicle overheating verified. The engine was observed reaching elevated temperatures after approximately ten minutes at idle. Inspection of the cooling system revealed coolant leaking from the water pump weep hole, indicating internal seal failure. The thermostat was also inspected and found to be functioning intermittently.</p>
              </div>
              <div class="bg-white rounded-lg p-4 border-l-4 border-blue-500">
                <div class="text-xs font-bold text-blue-600 uppercase tracking-wider mb-1">Correction</div>
                <p class="text-sm text-gray-700">Replaced the water pump due to weep hole seal failure. Replaced the thermostat as a preventive measure given its intermittent operation. Refilled the cooling system with manufacturer-specified coolant and performed a full system bleed. Ran the engine at operating temperature for fifteen minutes. Confirmed no leaks present and temperature gauge reading within normal range.</p>
              </div>
            </div>
          </div>

          <!-- Grade phase -->
          <div id="grade-phase" class="hidden mt-4">
            <div class="bg-white rounded-lg p-4 border border-teal/20">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-sm text-gray-500">Overall Story Grade</span>
                <span class="text-2xl font-extrabold text-teal">A-</span>
              </div>
              <div class="grid grid-cols-2 gap-2 text-xs">
                <div class="flex items-center gap-2"><span class="w-6 h-6 rounded bg-green-100 text-green-700 font-bold flex items-center justify-center">A</span> Customer Complaint</div>
                <div class="flex items-center gap-2"><span class="w-6 h-6 rounded bg-green-100 text-green-700 font-bold flex items-center justify-center">A</span> Complaint Verification</div>
                <div class="flex items-center gap-2"><span class="w-6 h-6 rounded bg-yellow-100 text-yellow-700 font-bold flex items-center justify-center">B</span> Diagnostics Performed</div>
                <div class="flex items-center gap-2"><span class="w-6 h-6 rounded bg-green-100 text-green-700 font-bold flex items-center justify-center">A</span> Component Involved</div>
                <div class="flex items-center gap-2"><span class="w-6 h-6 rounded bg-green-100 text-green-700 font-bold flex items-center justify-center">A</span> Root Cause</div>
                <div class="flex items-center gap-2"><span class="w-6 h-6 rounded bg-green-100 text-green-700 font-bold flex items-center justify-center">A</span> Repair Action</div>
                <div class="flex items-center gap-2"><span class="w-6 h-6 rounded bg-yellow-100 text-yellow-700 font-bold flex items-center justify-center">B</span> Final Verification</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Additional proof: screenshots -->
    <div class="grid md:grid-cols-2 gap-8">
      <div class="text-center">
        <img
          src="/report-card-screens/desktop_A2.png"
          alt="A-grade report card showing complete 3Cs documentation"
          class="rounded-2xl shadow-lg mx-auto mb-4"
          loading="lazy"
        >
        <p class="text-sm text-gray-500">Complete 3Cs documentation with automatic grading</p>
      </div>
      <div class="text-center">
        <img
          src="/MPI-screens/final_summary.PNG"
          alt="MPI summary showing findings categorized by severity"
          class="w-64 md:w-72 rounded-3xl shadow-lg mx-auto mb-4"
          loading="lazy"
        >
        <p class="text-sm text-gray-500">Voice-first MPI catches findings that manual inspections miss</p>
      </div>
    </div>
  </div>
</section>

<script>
  // Before/After typing animation
  const typedEl = document.getElementById('typed-text');
  const cursorEl = document.getElementById('cursor');
  const typeTimer = document.getElementById('type-timer');
  const voiceText = document.getElementById('voice-text');
  const voiceTimer = document.getElementById('voice-timer');
  const voicePhase = document.getElementById('voice-phase');
  const threecsPhase = document.getElementById('threecs-phase');
  const gradePhase = document.getElementById('grade-phase');

  // Typing content with actions
  const typeActions = [
    { type: 'text', value: 'Verified vehical is overheating.' },
    { type: 'pause', ms: 3000 },
    { type: 'text', value: ' found waterpump leeking' },
    { type: 'delete', count: 6 },
    { type: 'text', value: 'leaking from the weep hole.' },
    { type: 'pause', ms: 4000 },
    { type: 'text', value: ' replaced water pump' },
    { type: 'pause', ms: 2000 },
    { type: 'text', value: ' and therm' },
    { type: 'pause', ms: 2000 },
    { type: 'text', value: 'ostat.' },
    { type: 'pause', ms: 3000 },
    { type: 'text', value: ' filled' },
    { type: 'delete', count: 6 },
    { type: 'text', value: 're-filled coolant' },
    { type: 'pause', ms: 5000 },
    { type: 'text', value: ' no leaks.' },
  ];

  const voiceContent = "Ok, I verified the overheating issue, let it idle for about ten minutes and yeah the gauge climbed right up. The water pump's leaking from the weep hole. Uh, the thermostat was also... actually it was working but not perfect so I'm replacing that. I put in the new pump and thermostat, refilled the coolant, let it run for uh... fifteen minutes. No leaks, temp is good.";

  let observed = false;
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting && !observed) {
        observed = true;
        startAnimations();
      }
    });
  }, { threshold: 0.3 });

  const container = document.getElementById('before-after-container');
  if (container) observer.observe(container);

  function startAnimations() {
    runTyping();
    runVoice();
  }

  async function runTyping() {
    let text = '';
    let elapsed = 0;
    const charMs = 100; // ~25 WPM

    for (const action of typeActions) {
      if (action.type === 'text') {
        for (const char of action.value) {
          text += char;
          if (typedEl) typedEl.textContent = text;
          elapsed += charMs;
          updateTimer(typeTimer, elapsed);
          await sleep(charMs);
        }
      } else if (action.type === 'pause') {
        const steps = Math.floor(action.ms / 200);
        for (let i = 0; i < steps; i++) {
          elapsed += 200;
          updateTimer(typeTimer, elapsed);
          await sleep(200);
        }
      } else if (action.type === 'delete') {
        for (let i = 0; i < action.count; i++) {
          text = text.slice(0, -1);
          if (typedEl) typedEl.textContent = text;
          elapsed += 80;
          updateTimer(typeTimer, elapsed);
          await sleep(80);
        }
      }
    }
    // Keep cursor blinking after done
  }

  async function runVoice() {
    let elapsed = 0;
    // Phase 1: Voice recording (show text appearing word by word)
    const words = voiceContent.split(' ');
    for (let i = 0; i < words.length; i++) {
      const partial = words.slice(0, i + 1).join(' ');
      if (voiceText) voiceText.textContent = partial;
      elapsed += 150;
      updateTimer(voiceTimer, elapsed);
      await sleep(150);
    }

    // Brief pause
    await sleep(500);
    elapsed += 500;
    updateTimer(voiceTimer, elapsed);

    // Phase 2: Processing
    if (voicePhase) voicePhase.innerHTML = '<div class="flex items-center gap-3 p-4"><div class="w-5 h-5 border-2 border-teal border-t-transparent rounded-full animate-spin"></div><span class="text-sm text-gray-500">Generating 3Cs story...</span></div>';
    await sleep(1500);
    elapsed += 1500;
    updateTimer(voiceTimer, elapsed);

    // Phase 3: Show 3Cs
    if (voicePhase) voicePhase.classList.add('hidden');
    if (threecsPhase) threecsPhase.classList.remove('hidden');
    await sleep(1000);
    elapsed += 1000;
    updateTimer(voiceTimer, elapsed);

    // Phase 4: Show grade
    if (gradePhase) gradePhase.classList.remove('hidden');
  }

  function updateTimer(el, ms) {
    if (!el) return;
    const s = Math.floor(ms / 1000);
    const m = Math.floor(s / 60);
    const sec = s % 60;
    el.textContent = `${m}:${sec.toString().padStart(2, '0')}`;
  }

  function sleep(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }
</script>
