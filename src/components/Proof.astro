<style>
  @keyframes waveform-pulse {
    0%, 100% { height: 4px; }
    50% { height: 28px; }
  }
  .waveform-bar {
    height: 4px;
    transition: height 0.15s ease;
  }
  .waveform-active .waveform-bar {
    animation: waveform-pulse 0.6s ease-in-out infinite;
  }
  .waveform-active .waveform-bar:nth-child(1) { animation-delay: 0.00s; }
  .waveform-active .waveform-bar:nth-child(2) { animation-delay: 0.05s; }
  .waveform-active .waveform-bar:nth-child(3) { animation-delay: 0.10s; }
  .waveform-active .waveform-bar:nth-child(4) { animation-delay: 0.15s; }
  .waveform-active .waveform-bar:nth-child(5) { animation-delay: 0.20s; }
  .waveform-active .waveform-bar:nth-child(6) { animation-delay: 0.25s; }
  .waveform-active .waveform-bar:nth-child(7) { animation-delay: 0.30s; }
  .waveform-active .waveform-bar:nth-child(8) { animation-delay: 0.35s; }
  .waveform-active .waveform-bar:nth-child(9) { animation-delay: 0.40s; }
  .waveform-active .waveform-bar:nth-child(10) { animation-delay: 0.45s; }
  .waveform-active .waveform-bar:nth-child(11) { animation-delay: 0.50s; }
  .waveform-active .waveform-bar:nth-child(12) { animation-delay: 0.55s; }
  .waveform-active .waveform-bar:nth-child(13) { animation-delay: 0.60s; }
  .waveform-active .waveform-bar:nth-child(14) { animation-delay: 0.65s; }
  .waveform-active .waveform-bar:nth-child(15) { animation-delay: 0.70s; }
  .waveform-active .waveform-bar:nth-child(16) { animation-delay: 0.75s; }
  .waveform-active .waveform-bar:nth-child(17) { animation-delay: 0.80s; }
  .waveform-active .waveform-bar:nth-child(18) { animation-delay: 0.85s; }
  .waveform-active .waveform-bar:nth-child(19) { animation-delay: 0.90s; }
  .waveform-active .waveform-bar:nth-child(20) { animation-delay: 0.95s; }
  .waveform-active .waveform-bar:nth-child(21) { animation-delay: 1.00s; }
  .waveform-active .waveform-bar:nth-child(22) { animation-delay: 1.05s; }
