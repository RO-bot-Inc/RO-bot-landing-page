<section class="py-20 md:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-extrabold text-navy mb-6 animate-on-scroll">
        Don't Take Our Word For It
      </h2>
    </div>

    <div class="max-w-5xl mx-auto animate-on-scroll stagger-2">
      <!-- Dealership background image -->
      <div class="relative rounded-2xl overflow-hidden">
        <img
          src="/images/audi-morton-grove.png"
          alt="McGrath Audi of Morton Grove dealership"
          class="w-full h-[400px] md:h-[480px] object-cover object-center"
          loading="lazy"
        />
        <!-- Dark overlay for readability -->
        <div class="absolute inset-0 bg-gradient-to-r from-navy/90 via-navy/80 to-navy/40"></div>

        <!-- Content overlay -->
