---
const year = new Date().getFullYear();
---

<footer class="bg-navy text-white/70">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-10">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="flex items-end gap-2 mb-4">
          <img src="/head only.svg" alt="R.O. bot" class="h-6 w-auto mb-0.5">
          <span class="text-white font-bold text-[1.18rem] leading-none">R.O. bot</span>
        </a>
        <p class="text-sm leading-relaxed">
          Voice-first AI platform for automotive service departments.
        </p>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Product</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/product#3cs" class="hover:text-white transition-colors">3Cs Documentation</a></li>
          <li><a href="/product#video" class="hover:text-white transition-colors">Video Inspections</a></li>
          <li><a href="/product#mpi" class="hover:text-white transition-colors">Multi-Point Inspections</a></li>
          <li><a href="/pricing" class="hover:text-white transition-colors">Pricing</a></li>
          <li><a href="/book-demo" class="hover:text-white transition-colors">Book a Demo</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Company</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/about" class="hover:text-white transition-colors">About</a></li>
          <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
          <li><a href="/support" class="hover:text-white transition-colors">Support</a></li>
          <li><a href="https://app.ro-bot.io" target="_blank" rel="noopener" class="hover:text-white transition-colors">Log In</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Legal</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-white transition-colors">Terms of Service</a></li>
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Connect</h4>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="https://www.linkedin.com/company/ro-bot" target="_blank" rel="noopener" class="hover:text-white transition-colors flex items-center gap-2">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
          </li>
          <li>
            <a href="mailto:hello@ro-bot.io" class="hover:text-white transition-colors">hello@ro-bot.io</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/10 text-sm text-center">
      &copy; {year} R.O. bot, Inc. All rights reserved.
    </div>
  </div>
</footer>
