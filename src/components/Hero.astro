<section class="relative bg-navy pt-28 pb-20 md:pt-36 md:pb-28 overflow-hidden">
  <!-- Background image with parallax (slowest - furthest layer) -->
  <div class="absolute inset-0 opacity-20" data-parallax-bg data-parallax-speed="0.15">
    <img src="/hero/inspection.png" alt="" class="w-full h-full object-cover scale-110" loading="eager">
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Copy with subtle parallax -->
      <div data-parallax data-parallax-speed="0.05">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-[1.1] tracking-tight mb-6 animate-on-scroll">
          Turn Every Technician Into Your Most Profitable Technician
        </h1>
        <p class="text-2xl md:text-3xl text-muted leading-relaxed mb-8 max-w-lg animate-on-scroll stagger-2">
          Voice-first app that reduces screen time and increases revenue per RO.
        </p>
        <a href="/book-demo" class="inline-block bg-teal hover:bg-teal-dark text-white font-semibold px-8 py-4 rounded-lg text-lg transition-colors animate-on-scroll stagger-3">
          Book Your Demo
        </a>
      </div>

      <!-- Phone mockup with voice card -->
      <div class="flex justify-center">
        <div class="relative animate-scale-in">
          <img
            src="/product3d/left-phone-only.png"
            alt="R.O. bot app on phone"
            class="w-64 md:w-80 drop-shadow-2xl"
            data-parallax data-parallax-speed="-0.28"
            loading="eager"
          >

          <!-- Voice transcript card (single unit, consistent 70% opacity) -->
          <div class="voice-card absolute bottom-[100px] -left-12 md:-left-20 w-[260px] md:w-[320px] rounded-xl overflow-hidden shadow-2xl" data-parallax data-parallax-speed="-0.14">
            <!-- Text area - fixed height for 3 lines -->
            <div class="voice-card-inner px-4 pt-3">
              <p id="hero-transcript" class="text-white text-base md:text-lg font-semibold leading-snug h-[4.5rem] md:h-[5rem]">
                <span class="transcript-word"></span>
              </p>
            </div>
            <!-- Waveform video -->
            <div class="voice-card-inner">
              <video autoplay muted loop playsinline class="w-full block">
                <source src="/hero/waveform-white-on-black.mp4" type="video/mp4">
              </video>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Word-by-word transcript animation
  (function() {
    const transcripts = [
      "The engine compartment looks pretty clean overall. No leaks that I can see.",
      "There's a bit of corrosion around the battery terminals.",
      "Looks like a cracked hose right here...",
      "Brake pads are at about 4 millimeters. I'd recommend replacing them soon.",
    ];

    const container = document.getElementById('hero-transcript');
    if (!container) return;

    let currentTranscript = 0;
    let currentWord = 0;
    let words: string[] = [];

    function typeNextWord() {
      if (currentWord < words.length) {
        const span = document.createElement('span');
        span.className = 'transcript-word';
        span.textContent = (currentWord > 0 ? ' ' : '') + words[currentWord];
        container.appendChild(span);

        requestAnimationFrame(() => {
          span.classList.add('visible');
        });

        currentWord++;
        setTimeout(typeNextWord, 100 + Math.random() * 50);
      } else {
        setTimeout(startNextTranscript, 2500);
      }
    }

    function startNextTranscript() {
      container.style.opacity = '0';

      setTimeout(() => {
        container.innerHTML = '';
        currentTranscript = (currentTranscript + 1) % transcripts.length;
        words = transcripts[currentTranscript].split(' ');
        currentWord = 0;
        container.style.opacity = '1';
        typeNextWord();
      }, 300);
    }

    words = transcripts[0].split(' ');
    container.innerHTML = '';
    setTimeout(typeNextWord, 800);
  })();
</script>

<style>
  /*
   * Voice card with consistent 70% opacity throughout.
   * Using opacity on the whole card ensures both text area
   * and video have the same transparency level.
   */
  .voice-card {
    opacity: 0.85;
    background: #000;
  }

  .voice-card-inner {
    background: #000;
  }

  #hero-transcript {
    transition: opacity 0.3s ease;
  }

  .transcript-word {
    opacity: 0;
    display: inline;
    transition: opacity 0.12s ease;
  }

  .transcript-word.visible {
    opacity: 1;
  }
</style>
