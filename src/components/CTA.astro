<section class="py-20 md:py-28 bg-navy">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">
      Every RO Has More Revenue In It
    </h2>
    <p class="text-lg text-muted mb-10">
      Book a 15-minute demo and see how RO-bot works with your team's real workflow.
    </p>

    <form name="demo-request" method="POST" data-netlify="true" action="/thank-you" class="max-w-md mx-auto space-y-4">
      <input type="hidden" name="form-name" value="demo-request">
      <input
        type="text"
        name="name"
        placeholder="Your Name"
        required
        class="w-full px-5 py-3 rounded-lg text-navy bg-white border-0 focus:outline-none focus:ring-2 focus:ring-teal"
      >
      <input
        type="email"
        name="email"
        placeholder="Your Email"
        required
        class="w-full px-5 py-3 rounded-lg text-navy bg-white border-0 focus:outline-none focus:ring-2 focus:ring-teal"
      >
      <input
        type="text"
        name="dealership"
        placeholder="Shop / Dealership Name"
        class="w-full px-5 py-3 rounded-lg text-navy bg-white border-0 focus:outline-none focus:ring-2 focus:ring-teal"
      >
      <button
        type="submit"
        class="w-full bg-teal hover:bg-teal-dark text-white font-semibold px-8 py-4 rounded-lg text-lg transition-colors"
      >
        Book Your Demo
      </button>
    </form>
  </div>
</section>
