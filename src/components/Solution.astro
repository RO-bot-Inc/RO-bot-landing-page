<script>
  // MPI animation: toggle between voice notes and findings applied
  const before = document.getElementById('mpi-before');
  const after = document.getElementById('mpi-after');
  if (before && after) {
    let showing = 'before';
    setInterval(() => {
      if (showing === 'before') {
        before.style.opacity = '0';
        after.style.opacity = '1';
        showing = 'after';
      } else {
        before.style.opacity = '1';
        after.style.opacity = '0';
        showing = 'before';
      }
    }, 3000);
  }

  // R.O. bot demo animation
  const voiceTextEl = document.getElementById('voice-text');
  const timerEl = document.getElementById('demo-timer');
  const waveformEl = document.getElementById('waveform');
  const recDot = document.getElementById('rec-dot');
  const recLabel = document.getElementById('rec-label');

  const phaseVoice = document.getElementById('phase-voice');
  const phaseWriting = document.getElementById('phase-writing');
  const phaseStory = document.getElementById('phase-story');
  const phaseGrading = document.getElementById('phase-grading');
  const phaseGrade = document.getElementById('phase-grade');

  const voiceContent = "Ok, I verified the overheating issue, let it idle for about ten minutes and yeah the gauge climbed right up. The water pump's leaking from the weep hole. Uh, the thermostat was also... actually it was working but not perfect so I'm replacing that. I put in the new pump and thermostat, refilled the coolant, let it run for uh... fifteen minutes. No leaks, temp is good.";

  let demoObserved = false;
  const demoObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting && !demoObserved) {
        demoObserved = true;
        runDemoLoop();
      }
    });
  }, { threshold: 0.3 });

  const demoContainer = document.getElementById('robo-demo');
  if (demoContainer) demoObserver.observe(demoContainer);

  async function runDemoLoop() {
    while (true) {
      await runDemo();
      await sleep(3000);
      resetDemo();
    }
  }

  function resetDemo() {
    if (voiceTextEl) voiceTextEl.textContent = '';
    if (timerEl) timerEl.textContent = '0:00';
    if (waveformEl) waveformEl.classList.remove('waveform-active');
    if (recDot) recDot.classList.add('animate-pulse');
    if (recLabel) recLabel.textContent = 'Recording...';
    show(phaseVoice);
    hide(phaseWriting);
    hide(phaseStory);
    hide(phaseGrading);
    hide(phaseGrade);
  }

  async function runDemo() {
    let elapsed = 0;
    if (waveformEl) waveformEl.classList.add('waveform-active');
    const words = voiceContent.split(' ');
    for (let i = 0; i < words.length; i++) {
      if (voiceTextEl) voiceTextEl.textContent = words.slice(0, i + 1).join(' ');
      elapsed += 150;
      updateTimer(elapsed);
      await sleep(150);
    }
    if (waveformEl) waveformEl.classList.remove('waveform-active');
    if (recDot) recDot.classList.remove('animate-pulse');
    if (recLabel) recLabel.textContent = 'Done';
    await sleep(500); elapsed += 500; updateTimer(elapsed);

    hide(phaseVoice); show(phaseWriting);
    await sleep(2000); elapsed += 2000; updateTimer(elapsed);

    hide(phaseWriting); show(phaseStory);
    await sleep(2000); elapsed += 2000; updateTimer(elapsed);

    show(phaseGrading);
    await sleep(1500); elapsed += 1500; updateTimer(elapsed);

    hide(phaseGrading); show(phaseGrade);
    elapsed += 500; updateTimer(elapsed);
  }

  function show(el) { if (el) el.classList.remove('hidden'); }
  function hide(el) { if (el) el.classList.add('hidden'); }
  function updateTimer(ms) {
    if (!timerEl) return;
    const s = Math.floor(ms / 1000);
    timerEl.textContent = `${Math.floor(s / 60)}:${(s % 60).toString().padStart(2, '0')}`;
  }
  function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }
</script>

