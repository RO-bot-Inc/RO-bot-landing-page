<script>
  // MPI animation: toggle between voice notes and findings applied
  const before = document.getElementById('mpi-before');
  const after = document.getElementById('mpi-after');
  if (before && after) {
    let showing = 'before';
    setInterval(() => {
      if (showing === 'before') {
        before.style.opacity = '0';
        after.style.opacity = '1';
        showing = 'after';
      } else {
        before.style.opacity = '1';
        after.style.opacity = '0';
        showing = 'before';
      }
    }, 3000);
  }
</script>
