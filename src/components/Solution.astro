<script>
  // MPI animation: scroll-triggered toggle between voice notes and findings applied
  const mpiBefore = document.getElementById('mpi-before');
  const mpiAfter = document.getElementById('mpi-after');
  const mpiContainer = document.getElementById('mpi-animation');

  let mpiRunId = 0;

  function resetMpi() {
    if (mpiBefore) mpiBefore.style.opacity = '1';
    if (mpiAfter) mpiAfter.style.opacity = '0';
  }

  async function runMpiLoop(id) {
    while (id === mpiRunId) {
      // Show "before" for 3s
      await sleep(3000);
      if (id !== mpiRunId) return;
      // Swap to "after"
      if (mpiBefore) mpiBefore.style.opacity = '0';
      if (mpiAfter) mpiAfter.style.opacity = '1';
      // Hold "after" for 3s
      await sleep(3000);
      if (id !== mpiRunId) return;
      // Swap back to "before"
      if (mpiBefore) mpiBefore.style.opacity = '1';
      if (mpiAfter) mpiAfter.style.opacity = '0';
    }
  }

  if (mpiContainer) {
    const mpiObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        mpiRunId++;
        resetMpi();
        if (entry.isIntersecting) {
          const id = mpiRunId;
          sleep(800).then(() => {
            if (id === mpiRunId) runMpiLoop(id);
          });
        }
      });
    }, { threshold: 0.3 });
    mpiObserver.observe(mpiContainer);
  }

  // R.O. bot stacked card demo animation
  const voiceTextEl = document.getElementById('voice-text');
  const timerEl = document.getElementById('demo-timer');
  const timerMirrors = document.querySelectorAll('.demo-timer-mirror');
  const waveformEl = document.getElementById('waveform');
  const recDot = document.getElementById('rec-dot');
  const recLabel = document.getElementById('rec-label');

  const cardRecording = document.getElementById('card-recording');
  const cardWriting = document.getElementById('card-writing');
  const cardGrading = document.getElementById('card-grading');

  const writingSpinner = document.getElementById('writing-spinner');
  const storyContent = document.getElementById('story-content');
  const gradingSpinner = document.getElementById('grading-spinner');
  const gradeContent = document.getElementById('grade-content');

  // Voice transcript with per-word delay (ms AFTER this word appears).
  // Bursts of fast words (~80-120ms), natural pauses at commas/periods (~400-600ms),
  // longer hesitations at "Uh," and "..." (~700-900ms).
  const voiceScript = [
    ["Ok,", 350], ["I", 80], ["verified", 100], ["the", 70], ["overheating", 120], ["issue,", 450],
    ["let", 90], ["it", 70], ["idle", 110], ["for", 80], ["about", 100], ["ten", 90], ["minutes", 130],
    ["and", 100], ["yeah", 120], ["the", 70], ["gauge", 110], ["climbed", 100], ["right", 80], ["up.", 600],
    ["The", 100], ["water", 90], ["pump's", 110], ["leaking", 100], ["from", 80], ["the", 70], ["weep", 110], ["hole.", 700],
    ["Uh,", 800], ["the", 90], ["thermostat", 120], ["was", 80], ["also...", 900],
    ["actually", 110], ["it", 70], ["was", 80], ["working", 100], ["but", 90], ["not", 80], ["perfect", 120],
    ["so", 90], ["I'm", 80], ["replacing", 110], ["that.", 550],
    ["I", 80], ["put", 70], ["in", 60], ["the", 70], ["new", 80], ["pump", 90], ["and", 70], ["thermostat,", 400],
    ["refilled", 110], ["the", 70], ["coolant,", 450],
    ["let", 80], ["it", 70], ["run", 80], ["for", 80], ["uh...", 850], ["fifteen", 120], ["minutes.", 600],
    ["No", 90], ["leaks,", 350], ["temp", 100], ["is", 70], ["good.", 300],
  ];

  let runId = 0; // incremented on each start; stale loops check this to self-cancel

  const demoObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        // Cancel any running animation, reset, then start fresh
        runId++;
        resetDemo();
        startAfterDelay(runId);
      } else {
        // Scrolled away: cancel running animation
        runId++;
        resetDemo();
      }
    });
  }, { threshold: 0.3 });

  const demoContainer = document.getElementById('robo-demo');
  if (demoContainer) demoObserver.observe(demoContainer);

  async function startAfterDelay(id) {
    await sleep(800);
    if (id !== runId) return; // cancelled
    runDemoLoop(id);
  }

  async function runDemoLoop(id) {
    while (id === runId) {
      await runDemo(id);
      if (id !== runId) return;
      await sleep(5000);
      if (id !== runId) return;
      resetDemo();
    }
  }

  function resetDemo() {
    // Disable transitions so reset is instant
    const cards = [cardRecording, cardWriting, cardGrading];
    cards.forEach(c => { if (c) c.style.transition = 'none'; });
    if (writingSpinner) writingSpinner.style.transition = 'none';
    if (gradingSpinner) gradingSpinner.style.transition = 'none';

    // Reset recording card
    if (voiceTextEl) voiceTextEl.textContent = '';
    updateTimer(0);
    if (waveformEl) waveformEl.classList.remove('waveform-active');
    if (recDot) recDot.classList.add('animate-pulse');
    if (recLabel) recLabel.textContent = 'Recording...';

    // Show only recording card, hide others (reset to above-card position)
    if (cardRecording) {
      cardRecording.style.opacity = '1';
    }
    if (cardWriting) {
      cardWriting.style.opacity = '0';
      cardWriting.style.transform = 'translateY(-40px)';
    }
    if (cardGrading) {
      cardGrading.style.opacity = '0';
      cardGrading.style.transform = 'translateY(-40px)';
    }

    // Reset spinner overlays (visible, covering content)
    if (writingSpinner) { writingSpinner.style.opacity = '1'; writingSpinner.style.pointerEvents = 'auto'; }
    if (gradingSpinner) { gradingSpinner.style.opacity = '1'; gradingSpinner.style.pointerEvents = 'auto'; }

    // Re-enable transitions on next frame
    requestAnimationFrame(() => {
      cards.forEach(c => { if (c) c.style.transition = ''; });
      if (writingSpinner) writingSpinner.style.transition = '';
      if (gradingSpinner) gradingSpinner.style.transition = '';
    });
  }

  async function runDemo(id) {
    let elapsed = 0;

    // Phase 1: Voice recording on card 1 (natural pacing)
    if (waveformEl) waveformEl.classList.add('waveform-active');
    let transcript = '';
    for (let i = 0; i < voiceScript.length; i++) {
      if (id !== runId) return;
      const [word, delay] = voiceScript[i];
      transcript += (i > 0 ? ' ' : '') + word;
      if (voiceTextEl) voiceTextEl.textContent = transcript;
      elapsed += delay;
      updateTimer(elapsed);
      await sleep(delay);
    }
    if (id !== runId) return;
    if (waveformEl) waveformEl.classList.remove('waveform-active');
    if (recDot) recDot.classList.remove('animate-pulse');
    if (recLabel) recLabel.textContent = 'Done';
    await sleep(500); elapsed += 500; updateTimer(elapsed);

    // Phase 2: Drop card 2 into position (writing spinner visible)
    if (id !== runId) return;
    if (cardWriting) {
      cardWriting.style.opacity = '1';
      cardWriting.style.transform = 'translateY(0)';
    }
    await sleep(3000); elapsed += 3000; updateTimer(elapsed);

    // Phase 3: Fade out writing spinner to reveal 3Cs story
    if (id !== runId) return;
    if (writingSpinner) { writingSpinner.style.opacity = '0'; writingSpinner.style.pointerEvents = 'none'; }
    await sleep(2500); elapsed += 2500; updateTimer(elapsed);

    // Phase 4: Drop card 3 into position (grading spinner visible)
    if (id !== runId) return;
    if (cardGrading) {
      cardGrading.style.opacity = '1';
      cardGrading.style.transform = 'translateY(0)';
    }
    await sleep(3000); elapsed += 3000; updateTimer(elapsed);

    // Phase 5: Fade out grading spinner to reveal grade
    if (id !== runId) return;
    if (gradingSpinner) { gradingSpinner.style.opacity = '0'; gradingSpinner.style.pointerEvents = 'none'; }
    elapsed += 500; updateTimer(elapsed);
  }

  function updateTimer(ms) {
    const s = Math.floor(ms / 1000);
    const t = `${Math.floor(s / 60)}:${(s % 60).toString().padStart(2, '0')}`;
    if (timerEl) timerEl.textContent = t;
    timerMirrors.forEach(m => m.textContent = t);
  }
  function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }
</script>

<style>
