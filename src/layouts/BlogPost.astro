---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: string;
  category: string;
  excerpt: string;
}

const { title, date, category, excerpt } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const isoDate = new Date(date).toISOString();
const canonicalPath = `/blog/${Astro.url.pathname.split('/blog/')[1] || ''}`;

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": excerpt,
  "datePublished": isoDate,
  "dateModified": isoDate,
  "author": {
    "@type": "Person",
    "name": "Dave Sonders"
  },
  "publisher": {
    "@type": "Organization",
    "name": "R.O. bot",
    "logo": {
      "@type": "ImageObject",
      "url": "https://ro-bot.io/browser.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://ro-bot.io${canonicalPath}`
  }
};
---

<BaseLayout
  title={`${title} - R.O. bot Blog`}
  description={excerpt}
  ogType="article"
  canonicalPath={canonicalPath}
  schemaJson={blogPostingSchema}
>

  <article>
    <header class="bg-navy pt-28 pb-12 md:pt-36 md:pb-16">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <span class="text-teal-light text-sm font-medium uppercase tracking-wider">{category}</span>
        <h1 class="text-3xl md:text-4xl font-extrabold text-white mt-3 mb-4 leading-tight">{title}</h1>
        <time class="text-muted text-sm">{formattedDate}</time>
      </div>
    </header>

    <div class="py-16 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 prose prose-lg prose-gray max-w-none">
        <slot />
      </div>
    </div>
  </article>

  <section class="py-16 bg-surface text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-navy mb-4">Ready to see R.O. bot in action?</h2>
      <a href="/book-demo" class="inline-block bg-teal hover:bg-teal-dark text-white font-semibold px-8 py-3 rounded-lg transition-colors">
        Book Your Demo
      </a>
    </div>
  </section>

</BaseLayout>
